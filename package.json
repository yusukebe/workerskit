{
  "name": "kakera-worker",
  "version": "0.2.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun run test:fixtures && vitest",
    "test:fixtures": "bun build ./test/fixtures/routes/*.ts --outdir=./test/prod/routes --format=esm --target=browser",
    "release": "bun run build && np"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260430.1",
    "hono": "^4.12.16",
    "np": "^11.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
