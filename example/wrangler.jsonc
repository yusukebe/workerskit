{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kakera-example",
  "main": "src/app.ts",
  "build": {
    "command": "bun run build",
    "watch_dir": "routes"
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "compatibility_date": "2026-03-17"
}
